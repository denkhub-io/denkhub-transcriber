{
  "name": "denkhub-transcriber",
  "version": "1.1.6",
  "description": "DenkHub Transcriber - Trascrizione audio/video locale con Whisper",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --config.directories.output=/tmp/transcribe-build",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "postinstall": "electron-rebuild"
  },
  "author": "DenkHub",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "electron-store": "^10.0.0",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "nodejs-whisper": "^0.2.9"
  }
}
